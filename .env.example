# =============================================================================
# Real-Time E-commerce Price Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Cloud Platform
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# -----------------------------------------------------------------------------
# Google Cloud Bigtable
# -----------------------------------------------------------------------------
BIGTABLE_INSTANCE_ID=price-intelligence
BIGTABLE_CLUSTER_ID=price-intelligence-c1
# For local emulator (Phase 2)
BIGTABLE_EMULATOR_HOST=localhost:8086

# -----------------------------------------------------------------------------
# BigQuery (used by dbt)
# -----------------------------------------------------------------------------
BIGQUERY_DATASET=price_intelligence
BIGQUERY_LOCATION=US

# -----------------------------------------------------------------------------
# Apache Airflow
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-generate-with-python-cryptography
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# -----------------------------------------------------------------------------
# PostgreSQL (Airflow metadata DB)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow

# -----------------------------------------------------------------------------
# Apache NiFi
# -----------------------------------------------------------------------------
NIFI_WEB_HTTP_PORT=8080
NIFI_USERNAME=admin
NIFI_PASSWORD=adminpassword123
NIFI_HOST=localhost

# -----------------------------------------------------------------------------
# Apache Kafka (optional streaming layer)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PRICES=raw_prices
KAFKA_TOPIC_ALERTS=price_alerts
KAFKA_GROUP_ID=price-intelligence-consumer

# Zookeeper
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# -----------------------------------------------------------------------------
# Scrapy / Scraping
# -----------------------------------------------------------------------------
SCRAPY_SETTINGS_MODULE=scrapers.settings
SCRAPE_INTERVAL_SECONDS=3600
USER_AGENT_ROTATION=true
PROXY_LIST=  # comma-separated proxy URLs (optional)

# Sites cibles
TARGET_SITE_1=https://books.toscrape.com
TARGET_SITE_2=https://quotes.toscrape.com

# Push destination (NiFi HTTP endpoint)
NIFI_INGEST_URL=http://localhost:8080/contentListener

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
DBT_PROFILES_DIR=./dbt_project
DBT_PROJECT_NAME=price_intelligence
DBT_TARGET=dev

# -----------------------------------------------------------------------------
# Streamlit Dashboard
# -----------------------------------------------------------------------------
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark
DASHBOARD_REFRESH_INTERVAL=30

# -----------------------------------------------------------------------------
# Prometheus / Grafana
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Great Expectations
# -----------------------------------------------------------------------------
GE_DATA_DOCS_PORT=8888

# -----------------------------------------------------------------------------
# GitHub / CI-CD
# -----------------------------------------------------------------------------
GITHUB_REPO=RADAHassan/Real-Time-E-commerce-Price-Intelligence-Platform
ARTIFACT_REGISTRY_REPO=us-central1-docker.pkg.dev/your-project/price-intelligence
